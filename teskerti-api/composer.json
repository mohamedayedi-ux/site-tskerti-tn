{
  "name": "teskerti/api",
  "description": "Teskerti Cinema Booking REST API",
  "type": "project",
  "require": {
    "php": "^8.2",
    "phpmailer/phpmailer": "^6.9",
    "endroid/qr-code": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\Controllers\\": "controllers/",
      "App\\Models\\":      "models/",
      "App\\Core\\":        "core/",
      "App\\Helpers\\":     "helpers/",
      "App\\Middleware\\":  "middleware/",
      "App\\Config\\":      "config/"
    }


  },
  "scripts": {
    "start": "php -S localhost:8000 -t public/"
  },
  "config": {
    "optimize-autoloader": true
  }
}
